{
  "expectation_suite_name": "fact_trips_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "trip_id" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "trip_id" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "fare_amount", "min_value": 0, "max_value": 5000 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "trip_distance", "min_value": 0, "max_value": 200 }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 100000, "max_value": 50000000 }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "tpep_pickup_datetime" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "passenger_count", "min_value": 1, "max_value": 9 }
    }
  ]
}
